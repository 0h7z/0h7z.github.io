// https://www.typescriptlang.org/tsconfig/
{
	"compilerOptions": {
		//* Type Checking
		"exactOptionalPropertyTypes": false,
		"noFallthroughCasesInSwitch": true,
		"noImplicitOverride": true,
		"noImplicitReturns": true,
		"noPropertyAccessFromIndexSignature": true,
		"noUncheckedIndexedAccess": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"strict": true,
		//* Modules
		"module": "Preserve", // NodeNext | Preserve
		"paths": { "vitepress/types/*": ["./node_modules/vitepress/types/*"] },
		"resolveJsonModule": true,
		//! TS2876: This relative import path is unsafe to rewrite because it looks like a file name
		// "rewriteRelativeImportExtensions": true, // Node.js
		//* JavaScript Support
		"checkJs": true,
		//* Interop Constraints
		"erasableSyntaxOnly": true, // Node.js
		"verbatimModuleSyntax": true, // Node.js
		//* Language and Environment
		"target": "ESNext" // ESNext
	},
	"include": ["*", "src/**/*", ".vitepress/**/*"],
	"exclude": ["node_modules"]
}
